// ============================================================================
// STARTUP
// ============================================================================

// virt-manager, virt-viewer, and Boxes are launched on demand via
// keybind — no need to autostart any of them at login.


// ============================================================================
// LAYOUT
// ============================================================================

layout {
    // VM windows and their consoles are often left running at fixed
    // sizes for long stretches — default gaps are fine as-is, no
    // special tuning needed here beyond what mx already sets.
}