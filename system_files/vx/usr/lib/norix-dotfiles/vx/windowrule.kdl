// ============================================================================
// VM MANAGER WINDOWS
// ============================================================================

window-rule {
    match app-id="virt-manager"
    match app-id="org.gnome.Boxes"

    open-floating          true
    default-column-width   { proportion 0.55; }
    default-window-height  { proportion 0.65; }
}


// ============================================================================
// VM CONSOLE / DISPLAY WINDOWS
// ============================================================================

// virt-viewer consoles should float and default to a size close to
// a typical guest resolution rather than being forced into a tile.
window-rule {
    match app-id="virt-viewer"

    open-floating          true
    default-column-width   { proportion 0.70; }
    default-window-height  { proportion 0.75; }
}

// Once a console window has keyboard/mouse grabbed by the guest OS,
// don't let background-effect compositing chew through frames —
// same reasoning as gx's game-window rule.
window-rule {
    match app-id="virt-viewer"

    background-effect {
        xray true
        blur false
    }
}