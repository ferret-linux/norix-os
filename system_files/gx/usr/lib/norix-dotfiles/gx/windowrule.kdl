// ============================================================================
// LAUNCHER WINDOWS (floating, small)
// ============================================================================

window-rule {
    match app-id="steam"
    match app-id="lutris"
    match app-id="com.usebottles.bottles"
    match app-id="goverlay"

    open-floating          true
    default-column-width   { proportion 0.55; }
    default-window-height  { proportion 0.70; }
}


// ============================================================================
// STEAM SUB-WINDOWS
// ============================================================================

// Steam's friends list, chat, and small popups shouldn't tile —
// they're meant to float freely alongside a game.
window-rule {
    match app-id="steam" title="^Friends List$"
    match app-id="steam" title="^Steam - News$"
    open-floating true
}

// The Steam Big Picture / game overlay should always be fullscreen.
window-rule {
    match app-id="steam" title="^Steam Big Picture Mode$"
    open-fullscreen true
}


// ============================================================================
// GAME WINDOWS (gamescope / Proton / Wine)
// ============================================================================

// gamescope sessions should always claim the whole output.
window-rule {
    match app-id="gamescope"
    open-fullscreen true
}

// ============================================================================
// PERFORMANCE
// ============================================================================

// Skip xray/background-blur compositing on any game window — pure
// overhead with no benefit once a game has focus.
window-rule {
    match app-id="gamescope"
    match title="^.*\.exe$"

    background-effect {
        xray true
        blur flase
    }
}