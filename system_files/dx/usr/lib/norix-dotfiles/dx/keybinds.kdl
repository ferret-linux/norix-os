binds {

    // ---------------------------------------------------------------
    // Editors / IDEs
    // ---------------------------------------------------------------
    Mod+N { spawn-sh "code --new-window"; }


    // ---------------------------------------------------------------
    // Containers / virtualization tooling
    // ---------------------------------------------------------------
    Mod+Shift+P { spawn-sh "pods"; }


    // ---------------------------------------------------------------
    // Terminal (dev-focused second terminal for logs/servers)
    // ---------------------------------------------------------------
    Mod+Shift+RETURN { spawn-sh "ghostty --title=dev-term"; }


    // ---------------------------------------------------------------
    // Waydroid
    // ---------------------------------------------------------------
    Mod+Shift+D { spawn-sh "waydroid"; }
}